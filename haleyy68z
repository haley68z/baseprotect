RunService.Heartbeat:Connect(function()
    if isEnabled and (tick() - lastTrigger >= COOLDOWN_TIME) then
        -- Scan ultra rapide
        for _, v in ipairs(pGui:GetDescendants()) do
            if v:IsA("TextLabel") and v.Visible then
                if v.Text:find("is stealing") or v.Text:find("Someone is stealing") then
                    local target = getThiefName()
                    if target then
                        lastTrigger = tick() -- On active le cooldown de 20s
                        sendMsg(":balloon " .. target)
                        break
                    end
                end
            end
        end
    end
end)

